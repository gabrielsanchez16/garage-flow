{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "src/server.ts",
  "alias": {
    "tanstack-start-manifest:v": "./empty.js",
    "tanstack-start-injected-head-scripts:v": "./empty.js",
    "#tanstack-router-entry": "./src/router.tsx",
    "#tanstack-start-entry": "./src/server.ts"
  }
}